# SpiderClaw Docker 环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# ==============================================
# 基础配置
# ==============================================
ENVIRONMENT=production
DEBUG=false

# ==============================================
# Webhook配置
# ==============================================
WEBHOOK__SECRET=your-github-webhook-secret-here
WEBHOOK__HOST=0.0.0.0
WEBHOOK__PORT=8000
WEBHOOK__RELOAD=false

# ==============================================
# Agent配置
# ==============================================
AGENT__ENABLED=true
AGENT__MAX_RETRIES=3
AGENT__MAX_CHANGE_LINES=20
AGENT__AUTO_CREATE_PR=true
AGENT__REQUIRE_HUMAN_APPROVAL=false
AGENT__PENDING_EVENT_AUTO_THRESHOLD=5

# ==============================================
# GitHub配置
# ==============================================
GITHUB__TOKEN=your-github-personal-access-token
GITHUB__API_URL=https://api.github.com
GITHUB__DEFAULT_BRANCH=main

# ==============================================
# OpenAI配置
# ==============================================
OPENAI__API_KEY=your-openai-api-key
OPENAI__BASE_URL=https://api.openai.com/v1
OPENAI__MODEL_NAME=gpt-4o
OPENAI__TIMEOUT=60

# ==============================================
# 飞书配置
# ==============================================
LARK__ENABLED=false
LARK__APP_ID=cli_xxxxxx
LARK__APP_SECRET=your-app-secret
# 通知用户列表（多个用逗号分隔）
LARK__NOTIFY_USERS=[]
# 通知群组列表（多个用逗号分隔）
LARK__NOTIFY_GROUPS=[]
# 多维表格配置
LARK__BASE_ENABLED=false
LARK__BASE_TOKEN=bascnxxxxxx
LARK__REPAIR_TABLE_ID=tblxxxxxx
LARK__AUTO_CREATE_TABLE=true
LARK__AUTO_FIX_FIELDS=true
LARK__AS_BOT=false
# 告警配置
LARK__ALERT_ON_FAILURE=true
LARK__ALERT_THRESHOLD=3
# 审批配置
LARK__APPROVAL_CODE=
LARK__APPROVAL_WIDGET_ID=

# ==============================================
# 日志配置
# ==============================================
LOGGING__LEVEL=INFO
LOGGING__DIR=/app/src/logs
LOGGING__RETENTION_DAYS=30
LOGGING__JSON_FORMAT=true

# ==============================================
# 代理配置（可选，用于访问GitHub等外部服务）
# ==============================================
# HTTP_PROXY=http://host.docker.internal:1080
# HTTPS_PROXY=http://host.docker.internal:1080
# NO_PROXY=localhost,127.0.0.1,spiderclaw,biz-server

# ==============================================
# 其他配置
# ==============================================
# Git 配置
GIT_SSL_NO_VERIFY=true